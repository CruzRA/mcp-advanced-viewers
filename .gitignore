# ── Ignore everything by default ──
*

# ── Allow pipeline scripts ──
!.gitignore
!.cursorindexingignore
!pipeline/
!pipeline/**

# ── Allow mcp_advanced scripts ──
!mcp_advanced/
!mcp_advanced/*.py

# ── But still ignore generated output & secrets inside allowed dirs ──
pipeline/output/
pipeline/credentials/*.json
pipeline/.env
pipeline/__pycache__/
mcp_advanced/output/
mcp_advanced/trajectories/
mcp_advanced/*.csv
mcp_advanced/__pycache__/

# ── OS / Python ──
.DS_Store
__pycache__/
*.pyc
