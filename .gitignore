# ── Ignore everything by default ──
*

# ── Allow docs/ for GitHub Pages ──
!docs/
!docs/**
!.gitignore
!.cursorindexingignore

# ── Allow pipeline scripts ──
!pipeline/
!pipeline/**

# ── Allow mcp_advanced scripts ──
!mcp_advanced/
!mcp_advanced/*.py

# ── But still ignore secrets & bulky data inside allowed dirs ──
pipeline/output/
pipeline/credentials/*.json
pipeline/.env
pipeline/__pycache__/
mcp_advanced/output/
mcp_advanced/trajectories/
mcp_advanced/*.csv
mcp_advanced/__pycache__/

# ── OS / Python ──
.DS_Store
__pycache__/
*.pyc
